# ============================================================
# .env.example — Variáveis de Ambiente do Assistente Médico
# ============================================================
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env no repositório

# --- Autenticação HuggingFace ---
# Necessário para baixar modelos privados como LLaMA 3
HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Configuração do Modelo ---
# Caminho do modelo base para fine-tuning
MODEL_BASE=meta-llama/Meta-Llama-3-8B
# Fallback caso LLaMA 3 não esteja disponível
MODEL_FALLBACK=mistralai/Mistral-7B-v0.1
# Caminho onde o modelo treinado será salvo
MODEL_PATH=/app/models/medical-llama3-qlora

# --- Configuração da Aplicação ---
# Porta da interface Gradio
APP_PORT=7860
# Modo de compartilhamento público do Gradio (true/false)
GRADIO_SHARE=false
# Ambiente de execução (development/production)
APP_ENV=development

# --- Configuração de Logs ---
# Nível de log (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO
# Caminho dos logs de interação
LOG_PATH=/app/logs/interactions.jsonl
# Caminho dos logs de treino
TRAINING_LOG_PATH=/app/logs/training_loss.png

# --- Configuração de Segurança ---
# Chave secreta para autenticação da interface (opcional)
SECRET_KEY=sua_chave_secreta_aqui

# --- RAG (Retrieval-Augmented Generation) ---
# Diretório dos documentos médicos para indexação
DOCS_PATH=/app/data/raw
# Caminho do índice FAISS
FAISS_INDEX_PATH=/app/data/processed/faiss_index
